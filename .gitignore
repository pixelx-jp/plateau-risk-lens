# Dependencies
node_modules

# Build output
dist
*.tsbuildinfo

# Test artifacts. Anchor `coverage` to repo root so it doesn't also match
# src/coverage/ (which is real source for the CoverageMeter module).
/coverage
playwright-report
test-results

# Local data
# `.artifacts/` holds bundles downloaded by scripts/fetch-artifacts.sh; too
# large for git and intentionally excluded from the SPA build (artifacts
# always live on a separate origin in production).
.artifacts
# Legacy location (removed): kept ignored in case an older checkout still has it.
public/artifacts

# Environment / local config
.env
.env.*
!.env.example

# Vite / dev caches
.vite
.cache

# OS metadata
.DS_Store
Thumbs.db

# Editor / IDE
.idea
.vscode
*.swp
*.swo

# AI assistant / agent local state — must NEVER be public. These directories
# can contain conversation history, internal prompts, project-specific
# memory, or credentials. Treat them like .env.
.claude
.claude/
CLAUDE.md
.cursor
.cursorrules
.cursorignore
.aider*
.continue
.codex
.windsurf
.copilot
.gpt
AGENTS.md
.specstory

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Wrangler local state (Cloudflare CLI)
.wrangler
