# Copy to .env.local to override defaults locally. None of these are secrets.

# Where the SPA fetches PMTiles + FGB + manifest from.
#   /artifacts                                — default; served by the dev
#                                                middleware from .artifacts/
#                                                or ../plateau-core/out_<slug>/
#   https://artifacts.plateau.yodolabs.jp       — Yodo Labs' production origin
#                                                (zero local storage needed)
# VITE_ARTIFACT_BASE_ROOT=/artifacts

# Which city slug to show on first load.
# VITE_DEFAULT_CITY_SLUG=shibuya

# Where scripts/fetch-artifacts.sh reads the bundle catalog.
# Override if you have your own mirror.
# PLATEAU_DISTRIBUTION_INDEX=https://github.com/pixelx-jp/plateau-bridge/releases/download/data-v1/index.json
